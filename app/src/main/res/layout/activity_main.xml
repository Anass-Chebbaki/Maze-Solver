<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1A2E"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Maze Solver"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4">

            <Button
                android:id="@+id/btnAstar"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="A*"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#2D2D4E"
                android:textColor="#AAAACC"
                style="@style/Widget.Material3.Button.TonalButton"/>

            <Button
                android:id="@+id/btnBfs"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="BFS"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#2D2D4E"
                android:textColor="#AAAACC"
                style="@style/Widget.Material3.Button.TonalButton"/>

            <Button
                android:id="@+id/btnDfs"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="DFS"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#2D2D4E"
                android:textColor="#AAAACC"
                style="@style/Widget.Material3.Button.TonalButton"/>

            <Button
                android:id="@+id/btnGreedy"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="Greedy"
                android:textSize="9sp"
                android:textStyle="bold"
                android:backgroundTint="#2D2D4E"
                android:textColor="#AAAACC"
                style="@style/Widget.Material3.Button.TonalButton"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Griglia  -->
    <com.example.mazesolver.MazeView
        android:id="@+id/mazeView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#1A1A2E"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/footer"/>

    <!-- Footer -->
    <LinearLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1A2E"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Selettore modalità disegno -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp"
            android:weightSum="3">

            <Button
                android:id="@+id/btnModeWall"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="Muro"
                android:textSize="13sp"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#2D2D4E"
                android:textColor="#AAAACC"
                style="@style/Widget.Material3.Button.TonalButton"/>

            <Button
                android:id="@+id/btnModeStart"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="Start"
                android:textSize="13sp"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#2D2D4E"
                android:textColor="#AAAACC"
                style="@style/Widget.Material3.Button.TonalButton"/>

            <Button
                android:id="@+id/btnModeGoal"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="Goal"
                android:textSize="13sp"
                android:backgroundTint="#2D2D4E"
                android:textColor="#AAAACC"
                style="@style/Widget.Material3.Button.TonalButton"/>

        </LinearLayout>

        <!-- Statistiche -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#2D2D4E"
                android:padding="8dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VISITATI"
                    android:textColor="#7777AA"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"/>
                <TextView
                    android:id="@+id/statVisited"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#2D2D4E"
                android:padding="8dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LUNGHEZZA"
                    android:textColor="#7777AA"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"/>
                <TextView
                    android:id="@+id/statLength"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#2D2D4E"
                android:padding="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TEMPO (ms)"
                    android:textColor="#7777AA"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"/>
                <TextView
                    android:id="@+id/statTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Bottoni azione -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:text="Azzera"
                android:textSize="15sp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#2D2D4E"
                android:textColor="#AAAACC"
                style="@style/Widget.Material3.Button.TonalButton"/>

            <Button
                android:id="@+id/btnSolve"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:text="Risolvi"
                android:textSize="15sp"
                android:backgroundTint="#4F46E5"
                android:textColor="#FFFFFF"
                style="@style/Widget.Material3.Button.TonalButton"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>